# MCP Server Configuration
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_DEBUG=false

# Data directory for storing documents and cache
MCP_DATA_DIR=~/.claude/skills/markitdown-mcp/data

# Maximum file size to process in MB
MCP_MAX_FILE_SIZE_MB=500

# Timeout for processing operations in seconds
MCP_TIMEOUT_SECONDS=300

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
